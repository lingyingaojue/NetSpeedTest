<Window x:Class="NetSpeedTest.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:NetSpeedTest.Converters"
        Title="历史记录" Height="520" Width="900"
        WindowStartupLocation="CenterOwner"
        Icon="/Resources/app.png"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <converters:RateDisplayConverter x:Key="RateDisplayConverter" />
        <converters:BytesDisplayConverter x:Key="BytesDisplayConverter" />
        <converters:DurationDisplayConverter x:Key="DurationDisplayConverter" />
        <converters:LatencyDisplayConverter x:Key="LatencyDisplayConverter" />
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ======== 历史记录表格 ======== -->
        <DataGrid Grid.Row="0" ItemsSource="{Binding Records}" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectedItem="{Binding SelectedRecord}"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="测速时间" Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                    Width="140" />
                <DataGridTextColumn Header="类型" Binding="{Binding TestType}" Width="45" />
                <DataGridTextColumn Header="配置" Binding="{Binding NodeName}" Width="80" />
                <DataGridTextColumn Header="线程" Binding="{Binding ThreadCount}" Width="40" />
                <DataGridTextColumn Header="下载平均" Binding="{Binding DownloadMbps, Converter={StaticResource RateDisplayConverter}}"
                                    Width="90" />
                <DataGridTextColumn Header="上传平均" Binding="{Binding UploadMbps, Converter={StaticResource RateDisplayConverter}}"
                                    Width="90" />
                <DataGridTextColumn Header="内网延迟" Binding="{Binding LatencyMs, Converter={StaticResource LatencyDisplayConverter}}"
                                    Width="70" />
                <DataGridTextColumn Header="外网延迟" Binding="{Binding WanLatencyMs, Converter={StaticResource LatencyDisplayConverter}}"
                                    Width="70" />
                <DataGridTextColumn Header="总均速" Binding="{Binding AverageTotalMbps, Converter={StaticResource RateDisplayConverter}}"
                                    Width="90" />
                <DataGridTextColumn Header="总流量" Binding="{Binding TotalBytes, Converter={StaticResource BytesDisplayConverter}}"
                                    Width="85" />
                <DataGridTextColumn Header="耗时" Binding="{Binding DurationSeconds, Converter={StaticResource DurationDisplayConverter}}"
                                    Width="80" />
                <DataGridTextColumn Header="网卡" Binding="{Binding NetworkAdapterName}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- ======== 底部分页栏 ======== -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="上一页"
                        Command="{Binding PreviousPageCommand}"
                        IsEnabled="{Binding CanGoPrevious}"
                        Width="70" />

                <TextBlock Grid.Column="1" Text="{Binding PageNumber, StringFormat='第 {0} 页'}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" VerticalAlignment="Center" Margin="16,0" />

                <TextBlock Grid.Column="2" Text="{Binding TotalPages, StringFormat='/ 共 {0} 页'}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0" />

                <Button Grid.Column="3" Content="下一页"
                        Command="{Binding NextPageCommand}"
                        IsEnabled="{Binding CanGoNext}"
                        Width="70" />

                <Button Grid.Column="4" Content="清除全部" Width="80" Margin="12,0,0,0"
                        Command="{Binding ClearAllRecordsCommand}"
                        Background="{StaticResource ErrorBrush}" />

                <Button Grid.Column="5" Content="删除选中"
                        Command="{Binding DeleteRecordCommand}"
                        Background="{StaticResource ErrorBrush}"
                        Width="80" Margin="12,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</Window>
