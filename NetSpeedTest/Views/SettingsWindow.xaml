<Window x:Class="NetSpeedTest.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xml:lang="en-US"
        Title="测速设置" Height="450" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 线程数 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="并发线程数" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                           Width="160" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ThreadCount, StringFormat={}{0}}" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Width="50" TextAlignment="Right" />
            </StackPanel>
            <Slider Minimum="0" Maximum="8" Value="{Binding ThreadIndex}"
                    IsSnapToTickEnabled="True" Ticks="0 1 2 3 4 5 6 7 8" />
        </StackPanel>

        <!-- 整体超时 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="测速时长 (秒)" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                           Width="160" VerticalAlignment="Center" />
                <TextBlock Text="{Binding TestTimeoutSec, StringFormat={}{0}}" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Width="50" TextAlignment="Right" />
            </StackPanel>
            <Slider Minimum="10" Maximum="600" Value="{Binding TestTimeoutSec}" TickFrequency="10" IsSnapToTickEnabled="True" />
        </StackPanel>

        <!-- 线程启动间隔 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="线程启动间隔 (毫秒)" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                           Width="160" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ThreadRampUpMs, StringFormat={}{0}}" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Width="50" TextAlignment="Right" />
            </StackPanel>
            <Slider Minimum="0" Maximum="2000" Value="{Binding ThreadRampUpMs}" TickFrequency="100" IsSnapToTickEnabled="True" />
        </StackPanel>

        <!-- 平均延迟 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="平均计量延迟 (秒)" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                           Width="160" VerticalAlignment="Center" />
                <TextBlock Text="{Binding AverageDelaySec, StringFormat={}{0}}" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Width="50" TextAlignment="Right" />
            </StackPanel>
            <Slider Minimum="1" Maximum="30" Value="{Binding AverageDelaySec}" TickFrequency="1" IsSnapToTickEnabled="True" />
        </StackPanel>

        <!-- 平滑窗口 -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="速率平滑窗口 (秒)" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                           Width="160" VerticalAlignment="Center" />
                <TextBlock Text="{Binding RateWindowSec, StringFormat={}{0:F1}}" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Width="50" TextAlignment="Right" />
            </StackPanel>
            <Slider Minimum="0.5" Maximum="10" Value="{Binding RateWindowSec}" TickFrequency="0.5" IsSnapToTickEnabled="True" />
        </StackPanel>

        <!-- 轮询间隔 -->
        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="网卡轮询间隔 (毫秒)" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                           Width="160" VerticalAlignment="Center" />
                <TextBlock Text="{Binding NicPollIntervalMs, StringFormat={}{0}}" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Width="50" TextAlignment="Right" />
            </StackPanel>
            <Slider Minimum="200" Maximum="5000" Value="{Binding NicPollIntervalMs}" TickFrequency="100" IsSnapToTickEnabled="True" />
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="保存" Width="80" Style="{StaticResource AccentButtonStyle}"
                    Command="{Binding SaveCommand}" />
            <Button Content="取消" Width="60" Margin="8,0,0,0"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>
