<Window x:Class="NetSpeedTest.Views.EulaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="用户协议与声明" Height="560" Width="700"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Icon="/Resources/app.png"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderText" Text="请仔细阅读以下协议，同意后方可使用本软件" FontSize="13"
                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12" />

        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding EulaText}" FontSize="11"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" LineHeight="18" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="DisagreeBtn" Content="撤销同意并退出" Width="130"
                    Style="{StaticResource DangerButtonStyle}" Click="Disagree_Click" />
            <Button x:Name="AgreeBtn" Content="同意" Width="80" Margin="12,0,0,0"
                    Style="{StaticResource AccentButtonStyle}" Click="Agree_Click" />
            <Button x:Name="CloseBtn" Content="关闭" Width="60" Margin="12,0,0,0"
                    Click="Close_Click" Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</Window>
