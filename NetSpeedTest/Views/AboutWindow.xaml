<Window x:Class="NetSpeedTest.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于" Height="460" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="NetSpeedTest" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="版本 V1.1.1" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
                <TextBlock Text="网络测速工具" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />

                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,20" Width="200" />

                <TextBlock Text="开发者" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="凌影傲爵" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />

                <TextBlock Text="AI 协作" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,16,0,0" />
                <TextBlock Text="DeepSeek" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />

                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,16" Width="200" />

                <TextBlock Text="更新日志" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />

                <ItemsControl ItemsSource="{Binding Changelog}" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4" Padding="4,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Version}" FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding Date}" FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="8,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Details}" Margin="0,3,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="确定" Width="80" Margin="0,10,0,0"
                        Style="{StaticResource AccentButtonStyle}" Click="Close_Click" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
