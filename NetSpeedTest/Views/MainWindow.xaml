<Window x:Class="NetSpeedTest.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:converters="clr-namespace:NetSpeedTest.Converters"
        Title="NetSpeedTest" Height="700" Width="1280" MinHeight="600" MinWidth="1000"
        Icon="/Resources/app.png"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <converters:RateDisplayConverter x:Key="RateDisplayConverter" />
        <converters:BytesDisplayConverter x:Key="BytesDisplayConverter" />
        <converters:DurationDisplayConverter x:Key="DurationDisplayConverter" />
        <converters:LatencyDisplayConverter x:Key="LatencyDisplayConverter" />
        <converters:BoolInverterConverter x:Key="BoolInverter" />
        <converters:NotNullConverter x:Key="NotNullConverter" />
        <converters:SpeedDisplayConverter x:Key="SpeedDisplayConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="0.6*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="0.4*" />
        </Grid.RowDefinitions>

        <!-- ===== 顶部导航栏 ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="NetSpeedTest" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,20,0" />

            <TextBlock Grid.Column="1" Text="配置" Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="12" Margin="16,0,6,0" VerticalAlignment="Center" />
            <ComboBox Grid.Column="2" Width="140"
                      ItemsSource="{Binding Profiles}"
                      SelectedItem="{Binding SelectedProfile}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Column="3" Text="活跃线程" Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="12" Margin="16,0,8,0" VerticalAlignment="Center" />
            <Border Grid.Column="4" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                    Padding="6,2" Margin="0,0,8,0" MinWidth="36">
                <TextBlock Text="{Binding ActiveThreadCount, StringFormat={}{0}}"
                           Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="12,0,0,0">
                <Button Content="下载测速" Width="80" Padding="8,6"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding StartDownloadTestCommand}"
                        IsEnabled="{Binding IsTesting, Converter={StaticResource BoolInverter}}" />
                <Button Content="上传测速" Width="80" Margin="4,0,0,0" Padding="8,6"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding StartUploadTestCommand}"
                        IsEnabled="{Binding IsTesting, Converter={StaticResource BoolInverter}}" />
                <Button Content="双向测速" Width="80" Margin="4,0,0,0" Padding="8,6"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding StartFullTestCommand}"
                        IsEnabled="{Binding IsTesting, Converter={StaticResource BoolInverter}}" />
            </StackPanel>

            <Button Grid.Column="6" Content="取消" Width="60"
                    Style="{StaticResource DangerButtonStyle}"
                    Command="{Binding CancelTestCommand}"
                    Visibility="{Binding IsTesting, Converter={StaticResource BoolToVisibility}}" />

            <Button Grid.Column="7" Content="配置管理" Width="80" Padding="8,6"
                    Command="{Binding OpenProfileConfigCommand}" />

            <Button Grid.Column="8" Content="历史记录" Width="80" Margin="6,0,0,0" Padding="8,6"
                    Command="{Binding OpenHistoryCommand}" />

            <Button Grid.Column="9" Content="设置" Width="60" Margin="6,0,0,0"
                    Command="{Binding OpenSettingsCommand}" />

            <Button Grid.Column="10" Content="用户协议" Width="86" Margin="6,0,0,0"
                    Command="{Binding OpenEulaCommand}" />

            <Button Grid.Column="11" Content="关于" Width="60" Margin="6,0,0,0"
                    Command="{Binding OpenAboutCommand}" />

            <TextBlock Grid.Column="12" Text="{Binding StatusText}" FontSize="12"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Margin="12,0,0,0" TextTrimming="CharacterEllipsis" />
        </Grid>

        <!-- ===== 主内容区：图表 + 侧边栏 ===== -->
        <Grid Grid.Row="1" Margin="0,0,0,10" x:Name="ChartGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="DlCol" Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="UlCol" Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 下载图表 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="下载速率" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource DownloadChartStroke}" Margin="0,0,0,8" />
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding DownloadChartSeries}"
                                        XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                                        TooltipPosition="Top" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- 上传监测（上传速率背景流量） -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="上传速率" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource UploadChartStroke}" Margin="0,0,0,8" />
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding UploadChartSeries}"
                                        XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                                        TooltipPosition="Top" />
                </Grid>
            </Border>
        </Grid>

        <!-- 全部网卡实时速率 -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding AllAdapterRates}" Margin="0,4,0,0" MinHeight="36">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4"
                            Padding="8,4" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource DownloadChartStroke}"
                                       VerticalAlignment="Center">
                                <Run Text="▼ " />
                                <Run Text="{Binding DownloadMbps, Converter={StaticResource RateDisplayConverter}}" />
                            </TextBlock>
                            <TextBlock FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource UploadChartStroke}"
                                       VerticalAlignment="Center" Margin="8,0,0,0">
                                <Run Text="▲ " />
                                <Run Text="{Binding UploadMbps, Converter={StaticResource RateDisplayConverter}}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ===== 底部：结果卡片 + 历史 ===== -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 结果摘要卡片 -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="测速时长" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding ElapsedSeconds, Converter={StaticResource DurationDisplayConverter}}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="下载速率" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding DownloadMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource DownloadChartStroke}"
                                       FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="下载平均" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding AverageDownloadMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="上传速率" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding UploadMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource UploadChartStroke}"
                                       FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="上行平均" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding AverageUploadMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="总速率" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding TotalRateMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="总均速" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding AverageTotalMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="总流量" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding TotalBytes, Converter={StaticResource BytesDisplayConverter}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="内网延迟" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding LatencyMs, Converter={StaticResource LatencyDisplayConverter}}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="外网延迟" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding WanLatencyMs, Converter={StaticResource LatencyDisplayConverter}}"
                                       Foreground="{StaticResource WarningBrush}"
                                       FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Button Content="导出" Width="50" VerticalAlignment="Center"
                            Command="{Binding ExportResultCommand}" FontSize="12"
                            Margin="10,0,0,0" />
                </StackPanel>
            </Border>

            <!-- 网卡详细信息 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Adapters}" Margin="0,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6"
                                    Padding="10,8" Margin="0,0,0,6">
                                <StackPanel>
                                    <!-- 标题栏 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#2EA043" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="已断开">
                                                            <Setter Property="Fill" Value="#DA3633" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <Border Background="{StaticResource AccentBrush}" CornerRadius="4"
                                                Padding="6,2" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding TypeName}" FontSize="12" Foreground="White" />
                                        </Border>
                                        <Border Background="{StaticResource AccentBrush}" CornerRadius="4"
                                                Padding="6,2" Margin="4,0,0,0">
                                            <TextBlock Text="{Binding LinkSpeedBps, Converter={StaticResource SpeedDisplayConverter}}"
                                                       FontSize="12" Foreground="White" />
                                        </Border>
                                    </StackPanel>
                                    <!-- 3×3 网卡详情 -->
                                    <UniformGrid Columns="3">
                                        <StackPanel>
                                            <TextBlock Text="IP 地址" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding IPAddress, TargetNullValue='—'}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource DownloadChartStroke}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="默认网关" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding Gateway, TargetNullValue='—'}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource SuccessBrush}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="子网掩码" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding SubnetMask, TargetNullValue='—'}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="MAC 地址" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding MacAddress, TargetNullValue='—'}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource WarningBrush}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="IPv6 地址" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding IPv6Address, TargetNullValue='—'}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="DNS 服务器" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding DnsServers, TargetNullValue='—'}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource UploadChartStroke}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="DHCP 服务器" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding DhcpServer, TargetNullValue='—'}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource DownloadChartStroke}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="MTU" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding Mtu, TargetNullValue='—'}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="连接状态" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding StatusText}" FontSize="16" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="已断开">
                                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
