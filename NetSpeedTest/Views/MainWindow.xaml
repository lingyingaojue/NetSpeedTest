<Window x:Class="NetSpeedTest.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:converters="clr-namespace:NetSpeedTest.Converters"
        Title="NetSpeedTest" Height="700" Width="1280" MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <converters:RateDisplayConverter x:Key="RateDisplayConverter" />
        <converters:BytesDisplayConverter x:Key="BytesDisplayConverter" />
        <converters:DurationDisplayConverter x:Key="DurationDisplayConverter" />
        <converters:LatencyDisplayConverter x:Key="LatencyDisplayConverter" />
        <converters:BoolInverterConverter x:Key="BoolInverter" />
        <converters:NotNullConverter x:Key="NotNullConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== 顶部导航栏 ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="NetSpeedTest" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,20,0" />

            <TextBlock Grid.Column="1" Text="配置" Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" Margin="16,0,6,0" VerticalAlignment="Center" />
            <ComboBox Grid.Column="2" Width="140"
                      ItemsSource="{Binding Profiles}"
                      SelectedItem="{Binding SelectedProfile}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Column="3" Text="活跃线程" Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" Margin="16,0,8,0" VerticalAlignment="Center" />
            <Border Grid.Column="4" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                    Padding="6,2" Margin="0,0,8,0" MinWidth="36">
                <TextBlock Text="{Binding ActiveThreadCount, StringFormat={}{0}}"
                           Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="12,0,0,0">
                <Button Content="下载测速" Width="80" Padding="8,6"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding StartDownloadTestCommand}"
                        IsEnabled="{Binding IsTesting, Converter={StaticResource BoolInverter}}" />
                <Button Content="上传测速" Width="80" Margin="4,0,0,0" Padding="8,6"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding StartUploadTestCommand}"
                        IsEnabled="{Binding IsTesting, Converter={StaticResource BoolInverter}}" />
                <Button Content="双向测速" Width="80" Margin="4,0,0,0" Padding="8,6"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding StartFullTestCommand}"
                        IsEnabled="{Binding IsTesting, Converter={StaticResource BoolInverter}}" />
            </StackPanel>

            <Button Grid.Column="6" Content="取消" Width="60"
                    Style="{StaticResource DangerButtonStyle}"
                    Command="{Binding CancelTestCommand}"
                    Visibility="{Binding IsTesting, Converter={StaticResource BoolToVisibility}}" />

            <Button Grid.Column="7" Content="配置管理" Width="80" Padding="8,6"
                    Command="{Binding OpenProfileConfigCommand}" />

            <Button Grid.Column="8" Content="历史记录" Width="80" Margin="6,0,0,0" Padding="8,6"
                    Command="{Binding OpenHistoryCommand}" />

            <Button Grid.Column="9" Content="设置" Width="60" Margin="6,0,0,0"
                    Command="{Binding OpenSettingsCommand}" />

            <Button Grid.Column="10" Content="用户协议" Width="86" Margin="6,0,0,0"
                    Command="{Binding OpenEulaCommand}" />

            <Button Grid.Column="11" Content="关于" Width="60" Margin="6,0,0,0"
                    Command="{Binding OpenAboutCommand}" />

            <TextBlock Grid.Column="12" Text="{Binding StatusText}" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Margin="12,0,0,0" TextTrimming="CharacterEllipsis" />
        </Grid>

        <!-- ===== 主内容区：图表 + 侧边栏 ===== -->
        <Grid Grid.Row="1" Margin="0,0,0,10" x:Name="ChartGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="DlCol" Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="UlCol" Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 下载图表 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="下载速率" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource DownloadChartStroke}" Margin="0,0,0,8" />
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding DownloadChartSeries}"
                                        XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                                        TooltipPosition="Top" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- 上传监测（上传速率背景流量） -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="上传速率" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource UploadChartStroke}" Margin="0,0,0,8" />
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding UploadChartSeries}"
                                        XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                                        TooltipPosition="Top" />
                </Grid>
            </Border>
        </Grid>

        <!-- 全部网卡实时速率 -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding AllAdapterRates}" Margin="0,4,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4"
                            Padding="8,4" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource DownloadChartStroke}"
                                       VerticalAlignment="Center">
                                <Run Text="▼ " />
                                <Run Text="{Binding DownloadMbps, Converter={StaticResource RateDisplayConverter}}" />
                            </TextBlock>
                            <TextBlock FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource UploadChartStroke}"
                                       VerticalAlignment="Center" Margin="8,0,0,0">
                                <Run Text="▲ " />
                                <Run Text="{Binding UploadMbps, Converter={StaticResource RateDisplayConverter}}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ===== 底部：结果卡片 + 历史 ===== -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="120" />
            </Grid.RowDefinitions>

            <!-- 结果摘要卡片 -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="测速时长" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding ElapsedSeconds, Converter={StaticResource DurationDisplayConverter}}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="下载速率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding DownloadMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource DownloadChartStroke}"
                                       FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="下载平均" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding AverageDownloadMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="上传速率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding UploadMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource UploadChartStroke}"
                                       FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="上行平均" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding AverageUploadMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="总速率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding TotalRateMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="总均速" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding AverageTotalMbps, Converter={StaticResource RateDisplayConverter}}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="总流量" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding TotalBytes, Converter={StaticResource BytesDisplayConverter}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="内网延迟" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding LatencyMs, Converter={StaticResource LatencyDisplayConverter}}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,6" />

                    <StackPanel Margin="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="外网延迟" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                            <TextBlock Text="{Binding WanLatencyMs, Converter={StaticResource LatencyDisplayConverter}}"
                                       Foreground="{StaticResource WarningBrush}"
                                       FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Button Content="导出" Width="50" VerticalAlignment="Center"
                            Command="{Binding ExportResultCommand}" FontSize="11"
                            Margin="10,0,0,0" />
                </StackPanel>
            </Border>

            <!-- 历史记录 -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid x:Name="RecentDataGrid" ItemsSource="{Binding RecentRecords}" MaxHeight="120" Height="120">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat={}{0:MM-dd HH:mm:ss}}"
                                            Width="110" />
                        <DataGridTextColumn Header="类型" Binding="{Binding TestType}" Width="45" />
                        <DataGridTextColumn Header="配置" Binding="{Binding NodeName}" Width="80" />
                        <DataGridTextColumn Header="线程" Binding="{Binding ThreadCount}" Width="40" />
                        <DataGridTextColumn Header="下载平均" Binding="{Binding DownloadMbps, Converter={StaticResource RateDisplayConverter}}"
                                            Width="90" />
                        <DataGridTextColumn Header="上传平均" Binding="{Binding UploadMbps, Converter={StaticResource RateDisplayConverter}}"
                                            Width="90" />
                        <DataGridTextColumn Header="内网延迟" Binding="{Binding LatencyMs, Converter={StaticResource LatencyDisplayConverter}}"
                                            Width="70" />
                        <DataGridTextColumn Header="外网延迟" Binding="{Binding WanLatencyMs, Converter={StaticResource LatencyDisplayConverter}}"
                                            Width="70" />
                        <DataGridTextColumn Header="总均速" Binding="{Binding AverageTotalMbps, Converter={StaticResource RateDisplayConverter}}"
                                            Width="90" />
                        <DataGridTextColumn Header="总流量" Binding="{Binding TotalBytes, Converter={StaticResource BytesDisplayConverter}}"
                                            Width="85" />
                        <DataGridTextColumn Header="耗时" Binding="{Binding DurationSeconds, Converter={StaticResource DurationDisplayConverter}}"
                                            Width="80" />
                        <DataGridTextColumn Header="网卡" Binding="{Binding NetworkAdapterName}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
